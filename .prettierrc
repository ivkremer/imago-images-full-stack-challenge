{
  "arrowParens": "always",
  "bracketSameLine": false,
  "jsxSingleQuote": false,
  "printWidth": 120,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "overrides": [
    {
      "files": ["*.css", "*.scss", "*.postcss"],
      "options": {
        "singleQuote": false
      }
    }
  ]
}
